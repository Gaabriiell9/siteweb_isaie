############################################################
#  Supabase Self-Hosted — Variables d'environnement
#  NE PAS committer ce fichier sur GitHub
############################################################

# ── Base de données ──────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_DB=postgres
# Port interne Docker (connexions inter-conteneurs via db:5432)
# Port hôte exposé : 5433  (cf. docker-compose.yml "5433:5432")
POSTGRES_PORT=5432
POSTGRES_PASSWORD=your-super-secret-password

# ── JWT ──────────────────────────────────────────────────
# JWT_SECRET doit faire au moins 32 caractères
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters
JWT_EXPIRY=3600

# Clés générées avec JWT_SECRET ci-dessus (HS256)
# payload anon  : {"role":"anon","iss":"supabase","iat":1641769200,"exp":1799535600}
# payload admin : {"role":"service_role","iss":"supabase","iat":1641769200,"exp":1799535600}
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlIiwiaWF0IjoxNjQxNzY5MjAwLCJleHAiOjE3OTk1MzU2MDB9.YJtPcwptZq-NGiwOvS-D8UBfvGO5-sAsrOHjPUG8YgQ
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoic3VwYWJhc2UiLCJpYXQiOjE2NDE3NjkyMDAsImV4cCI6MTc5OTUzNTYwMH0.982En3Hbn7eNWVGoHFHvxVys0DmkftXlKfwb9HNIda0

# ── URLs ─────────────────────────────────────────────────
SITE_URL=http://localhost:3000
API_EXTERNAL_URL=http://localhost:8000
SUPABASE_PUBLIC_URL=http://localhost:8000

# ── Studio ───────────────────────────────────────────────
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=admin123
STUDIO_DEFAULT_ORGANIZATION=Église Temple de la Célébration
STUDIO_DEFAULT_PROJECT=etc-church

# ── Auth (GoTrue) ─────────────────────────────────────────
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false
SMTP_ADMIN_EMAIL=admin@etc-church.local
SMTP_HOST=inbucket
# Port interne Docker (GoTrue → inbucket via réseau Docker, pas via l'hôte)
# Port hôte exposé : 2501  (cf. docker-compose.yml "2501:2500")
SMTP_PORT=2500
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=ETC Church

# ── Realtime ─────────────────────────────────────────────
# SECRET_KEY_BASE : 64 caractères minimum (Phoenix/Elixir)
SECRET_KEY_BASE=UpNVntn3cDxHJpq99YMc1T1AQgQpc8kfYTuRgBiYa15BLrx8etQoXz3gZv1u2oq
DB_ENC_KEY=supabaserealtime

# ── Storage ──────────────────────────────────────────────
STORAGE_BACKEND=file
FILE_SIZE_LIMIT=52428800

# ── imgproxy ─────────────────────────────────────────────
IMGPROXY_ENABLE_WEBP_DETECTION=true

# ── Studio logs (désactivé sans Logflare) ────────────────
LOGFLARE_API_KEY=
